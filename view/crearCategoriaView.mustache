{{>header}}

<div class="container-fluid lobby-container">
    <div class="row">

        <aside class="col-lg-2 sidebar">
            <div class="d-flex flex-column gap-3 px-3 mt-4">
                <a href="/editor/mostrarPreguntasReportadas" class="btn lobby-btn">Sugeridas</a>
                <a href="/editor/mostrarPreguntasReportadas" class="btn lobby-btn">Reportadas</a>
                <a href="/editor/irAPanelEditor" class="btn lobby-btn active">Preguntas</a>
            </div>
        </aside>

        <main class="col-lg-10 p-4">
            <div class="panel-editor-box p-4" style="background-color: #212529; border: 1px solid rgba(224, 169, 109, 0.3); border-radius: 12px; color: white;">

                <h2 class="panel-title mb-4" style="color: #e0a96d;">AGREGAR NUEVA CATEGORÍA</h2>

                 <form action="/editor/agregarCategoria" method="POST">
                    <div class="mb-4">
                        <label for="nombre_categoria" class="form-label fw-bold" style="color: #bbb;">Nombre de la Categoría:</label>
                        <input type="text"
                               class="form-control"
                               name="nombre_categoria"
                               id="nombre_categoria"
                               placeholder="Ej: Historia, Ciencia, Deportes..."
                               style="background-color: rgba(0,0,0,0.2); color: white; border: 1px solid #444; height: 45px;"
                               required>
                    </div>

                    <div class="mb-4" style="max-width: 300px;">
                        <label for="color_categoria" class="form-label fw-bold" style="color: #bbb;">Color:</label>
                        <div class="d-flex align-items-center gap-2">
                            <input type="color"
                                   class="form-control form-control-color"
                                   name="color_categoria"
                                   id="color_categoria"
                                   value="#ea9939"
                                   title="Elige un color para la categoría"
                                   style="background-color: rgba(0,0,0,0.2); border: 1px solid #444; width: 60px; height: 45px; cursor: pointer;">
                            <span class="text-muted small">Este color se usará en las etiquetas de las preguntas.</span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4 pt-3" style="border-top: 1px solid #343a40;">
                        <a href="/editor/irAPanelEditor" class="btn btn-secondary px-4">Cancelar</a>
                        <button type="submit" class="btn btn-primary px-4" style="background-color: #e0a96d; border: none; color: black; font-weight: bold;">Crear Categoría</button>
                    </div>

                </form>

            </div>
        </main>

    </div>
</div>

{{>footer}}