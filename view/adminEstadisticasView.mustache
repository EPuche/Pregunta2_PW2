{{>header}}

<div class="container-fluid lobby-container">
  <div class="row">

    <!-- Sidebar -->
    <aside class="col-lg-2 sidebar">
      <div class="d-flex flex-column gap-3 px-3">
        <a href="/admin/verEstadisticas" class="btn lobby-btn">Dashboard</a>
        <a href="/admin/usuarios" class="btn lobby-btn">Usuarios</a>
        <a href="/admin/partidas" class="btn lobby-btn">Partidas</a>
        <a href="/admin/preguntas" class="btn lobby-btn">Preguntas</a>
        <a href="/admin/trampitas" class="btn lobby-btn">Trampitas / Ventas</a>
        <a href="/logout" class="btn lobby-btn">Salir</a>
      </div>
    </aside>

    <!-- Main -->
    <main class="col-lg-10 p-4">

      <h2 class="panel-title mb-4">Panel Administrador</h2>

      <!-- Filtro + imprimir -->
      <div class="d-flex justify-content-between align-items-center mb-4">
        <form method="get" action="/admin/verEstadisticas" class="d-flex align-items-center gap-2">
          <label for="filtro" class="form-label text-light fw-bold">Filtrar por:</label>
          <select name="filtro" id="filtro" class="form-select form-select-sm filtro-select" onchange="this.form.submit()">
            <option value="dia" {{#esDia}}selected{{/esDia}}>Día</option>
            <option value="semana" {{#esSemana}}selected{{/esSemana}}>Semana</option>
            <option value="mes" {{#esMes}}selected{{/esMes}}>Mes</option>
            <option value="anio" {{#esAnio}}selected{{/esAnio}}>Año</option>
          </select>
        </form>
        <button class="btn btn-principal" onclick="window.print()">Imprimir reportes</button>
      </div>

      <!-- Métricas -->
      <div class="row g-4">
        <div class="col-md-3">
          <div class="panel stat-panel"><small>Usuarios totales</small><h2>{{usuariosTotales}}</h2></div>
        </div>
        <div class="col-md-3">
          <div class="panel stat-panel"><small>Nuevos usuarios</small><h2>{{usuariosNuevos}}</h2></div>
        </div>
        <div class="col-md-3">
          <div class="panel stat-panel"><small>Partidas jugadas</small><h2>{{partidasTotales}}</h2></div>
        </div>
        <div class="col-md-3">
          <div class="panel stat-panel"><small>Preguntas en juego</small><h2>{{preguntasTotales}}</h2></div>
        </div>
        <div class="col-md-3">
          <div class="panel stat-panel"><small>Preguntas creadas</small><h2>{{preguntasCreadas}}</h2></div>
        </div>
      </div>

      <!-- Gráficos -->
      <div class="row g-4 mt-4">
        <div class="col-md-4">
          <div class="panel chart-panel">
            <h5>% correctas promedio por usuario</h5>
            <canvas id="correctasChart" data-labels='{{{correctasLabels}}}' data-datos='{{{correctasDatos}}}'></canvas>
          </div>
        </div>
        <div class="col-md-4">
          <div class="panel chart-panel">
            <h5>Usuarios por sexo</h5>
            <canvas id="sexoChart" data-labels='{{{sexoLabels}}}' data-datos='{{{sexoDatos}}}'></canvas>
          </div>
        </div>
        <div class="col-md-4">
          <div class="panel chart-panel">
            <h5>Usuarios por edad</h5>
            <canvas id="edadChart" data-labels='{{{edadLabels}}}' data-datos='{{{edadDatos}}}'></canvas>
          </div>
        </div>
       

    </main>
  </div>
</div>

{{>footer}}
