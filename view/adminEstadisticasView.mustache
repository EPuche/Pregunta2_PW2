{{>header}}
<link href="../assets/styles/admin/imprimir.css" rel="stylesheet">

<div class="container-fluid lobby-container">
    <div class="row">

        <!-- Sidebar -->
        <aside class="col-lg-2 sidebar no-print">
            <div class="d-flex flex-column gap-3 px-3">
                <a href="/admin/verEstadisticas" class="btn lobby-btn">Dashboard</a>
                <a href="/admin/usuarios" class="btn lobby-btn">Usuarios</a>
                <a href="/logout" class="btn lobby-btn">Salir</a>
            </div>
        </aside>

        <!-- Main -->
        <main class="col-lg-10 p-4">

            <h2 class="panel-title mb-4">Panel Administrador</h2>

            <!-- Filtro + imprimir (no se imprime) -->
            <div class="d-flex justify-content-between align-items-center mb-4 no-print">
                <form method="get" action="/admin/verEstadisticas" class="d-flex align-items-center gap-2">
                    <label for="filtro" class="form-label text-light fw-bold">Filtrar por:</label>
                    <select name="filtro" id="filtro" class="form-select form-select-sm filtro-select"
                            onchange="this.form.submit()">
                        <option value="dia" {{#esDia}}selected{{/esDia}}>Día</option>
                        <option value="semana" {{#esSemana}}selected{{/esSemana}}>Semana</option>
                        <option value="mes" {{#esMes}}selected{{/esMes}}>Mes</option>
                        <option value="anio" {{#esAnio}}selected{{/esAnio}}>Año</option>
                    </select>
                </form>
                <button class="btn btn-principal no-print" onclick="window.print()">
                    Imprimir reportes
                </button>
            </div>

            <!-- Este SÍ se imprime -->
            <div id="reporte-imprimible">

                <!-- Métricas -->
                <div class="row g-4">
                    <div class="col-md-3">
                        <div class="panel stat-panel"><small>Usuarios totales</small>
                            <h2>{{usuariosTotales}}</h2></div>
                    </div>
                    <div class="col-md-3">
                        <div class="panel stat-panel"><small>Nuevos usuarios</small>
                            <h2>{{usuariosNuevos}}</h2></div>
                    </div>
                    <div class="col-md-3">
                        <div class="panel stat-panel"><small>Partidas jugadas</small>
                            <h2>{{partidasTotales}}</h2></div>
                    </div>
                    <div class="col-md-3">
                        <div class="panel stat-panel"><small>Preguntas en juego</small>
                            <h2>{{preguntasTotales}}</h2></div>
                    </div>
                    <div class="col-md-3">
                        <div class="panel stat-panel"><small>Preguntas creadas</small>
                            <h2>{{preguntasCreadas}}</h2></div>
                    </div>
                </div>

                <!-- Gráficos -->
                <div class="row g-4 mt-4">
                    <div class="col-md-4">
                        <div class="panel chart-panel">
                            <h5>% respuestas correctas por usuario</h5>
                            <canvas id="correctasChart" data-labels='{{{correctasLabels}}}'
                                    data-datos='{{{correctasDatos}}}'></canvas>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="panel chart-panel">
                            <h5>Usuarios por sexo</h5>
                            <canvas id="sexoChart" data-labels='{{{sexoLabels}}}' data-datos='{{{sexoDatos}}}'></canvas>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="panel chart-panel">
                            <h5>Usuarios por edad</h5>
                            <canvas id="edadChart" data-labels='{{{edadLabels}}}' data-datos='{{{edadDatos}}}'></canvas>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="panel chart-panel">

                            <h5>Usuarios por país</h5>
                            <canvas id="paisChart" data-labels='{{{paisLabels}}}' data-datos='{{{paisDatos}}}'></canvas>
                        </div>
                    </div>
                </div>

            </div> <!-- fin reporte-imprimible -->

        </main>
    </div>
</div>

{{>footer}}