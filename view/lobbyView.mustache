{{>header}}

<div class="container-fluid lobby-container">

    <div class="row min-vh-100">

        <!-- SIDEBAR -->
        <aside class="col-12 col-md-3 col-lg-2 sidebar">

            <div class="d-flex flex-column gap-3 p-3">

                <a href="/partida/crear" class="btn btn-warning fw-semibold">
                    Crear partida
                </a>

                <a href="/pregunta/crear" class="btn btn-warning fw-semibold">
                    Crear pregunta
                </a>

                <a href="/ranking" class="btn btn-warning fw-semibold">
                    Ver ranking
                </a>

                <a href="/usuario/verPerfil" class="btn btn-warning fw-semibold">
                    Ver perfil
                </a>

            </div>

        </aside>

        <!-- MAIN -->
        <main class="col-12 col-md-9 col-lg-10 p-4 main-content">

            <!-- PERFIL -->
            <section class="card user-card mb-4">

                <div class="card-body d-flex align-items-center gap-3">

                    <div class="user-avatar">
                        IMG
                    </div>

                    <div class="user-info">
                        <h4 class="mb-0">{{nombreUsuario}}</h4>
                        <small class="text-muted">Puntaje: {{puntaje}}</small>
                    </div>

                </div>

            </section>

            <!-- HISTORIAL -->
            <section class="card history-card">

                <div class="card-header bg-dark text-white">
                    Partidas jugadas
                </div>

                <div class="card-body p-0">

                    <div class="list-group list-group-flush">

                        {{#historial}}

                            <div class="list-group-item match-card d-flex justify-content-between align-items-center">

                                <div class="d-flex align-items-center gap-3">

                                    <div class="opponent-avatar">
                                        IMG
                                    </div>

                                    <div class="opponent-name">
                                        {{oponente}}
                                    </div>

                                </div>

                                <div class="match-result">
                                    {{resultado}}
                                </div>

                            </div>

                        {{/historial}}

                        {{^historial}}
                            <div class="p-3 text-muted">
                                No hay partidas jugadas.
                            </div>
                        {{/historial}}

                    </div>

                </div>

            </section>

        </main>

    </div>

</div>

{{>footer}}