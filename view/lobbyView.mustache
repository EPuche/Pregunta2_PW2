{{>header}}



<div class="container-fluid lobby-container">

    <div class="row">

        <!-- SIDEBAR -->

        <aside class="col-12 col-lg-2 sidebar">
            <div class="row g-2 px-2 w-100 m-0 justify-content-center">

                <div class="col-6 col-sm-3 col-lg-12">
                    <a href="/partida/crearPartida" class="btn lobby-btn w-100 text-center">
                        Crear partida
                    </a>
                </div>

                <div class="col-6 col-sm-3 col-lg-12">
                    <a href="/pregunta/irACrearPregunta" class="btn lobby-btn w-100 text-center">
                        Crear pregunta
                    </a>
                </div>

                <div class="col-6 col-sm-3 col-lg-12">
                    <a href="/ranking/irAlRanking" class="btn lobby-btn w-100 text-center">
                        Ver ranking
                    </a>
                </div>

                <div class="col-6 col-sm-3 col-lg-12">
                    <a href="/usuario/verPerfil" class="btn lobby-btn w-100 text-center">
                        Ver perfil
                    </a>
                </div>

            </div>
        </aside>

        <!-- CONTENIDO -->

        <main class="col-lg-10 p-4">

            <div class="row g-4">

                <!-- PERFIL -->

                <div class="col-lg-8">

                    <div class="panel profile-panel">

                        <div class="profile-content">

                            <img
                                src="{{fotoPerfil}}"
                                class="perfil-foto"
                                alt="perfil">

                            <div>

                                <div class="profile-name">
                                    {{nombreUsuario}}
                                </div>

                                <div class="profile-score">

                                    <small>Puntaje total</small>

                                    <strong>
                                        {{puntaje}}
                                    </strong>

                                </div>

                                <div class="profile-stats">

                                    <div class="stat-box">


                                        <i class="bi bi-bar-chart-fill"></i>

                                        <div>

                                            <small>Ranking</small>

                                            <strong>{{ranking}}</strong>

                                        </div>

                                    </div>

                                    <div class="stat-box">
                                        <button class="btn-plus" data-bs-toggle="modal" data-bs-target="#modalComprarTrampitas" aria-label="Comprar trampitas">
                                            <i class="bi bi-plus-square-fill icono-plus"></i>
                                        </button>
                                        <div>
                                            <small>Trampitas</small>
                                            <strong>{{trampitas}}</strong>
                                        </div>
                                    </div>

                                    <div class="modal fade" id="modalComprarTrampitas" tabindex="-1" aria-labelledby="modalTrampitasLabel" aria-hidden="true">
                                        <div class="modal-dialog modal-dialog-centered">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title" id="modalTrampitasLabel">🛒 Comprar Trampitas</h5>
                                                    <button type="type" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                </div>

                                                <form action="/trampitas/procesarPago" method="POST">
                                                    <div class="modal-body">
                                                        <p class="text-muted">Potencia tu juego adquiriendo trampitas para usar en tus partidas. ¡Cada una te cuesta <strong>$1.000 ARS</strong>!</p>

                                                        <div class="mb-3">
                                                            <label for="cantidadTrampitas" class="form-label">Cantidad a comprar:</label>
                                                            <input type="number" class="form-control form-control-lg text-center" id="cantidadTrampitas" name="cantidad" min="1" max="50" value="1" required>
                                                        </div>

                                                        <div class="p-3 bg-light rounded text-center">
                                                            <span class="d-block text-secondary small">Total a pagar</span>
                                                            <h3 class="m-0 text-success fw-bold" id="totalPrecio">$1.000</h3>
                                                            <input type="hidden" id="inputTotal" name="total" value="1000">
                                                        </div>
                                                    </div>

                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                                        <button type="submit" class="btn btn-primary px-4 fw-bold">Ir a Pagar con Mercado Pago</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>

                                </div>

                            </div>

                        </div>
                    </div>

                </div>

                <!-- HISTORIAL -->

                <div class="col-lg-4">
                      <h2 class="panel-title">
                            Partidas jugadas
                        </h2>
                    <div class="panel history-panel profile-panel-partidas-realizadas">

                        {{#historial}}

                        <div class="match-card ">

                            <div class="player-info">

                                <div class="player-avatar">

                                    <img
                                          src="{{foto_oponente}}"
                                          alt="Avatar del {{oponente}}">

                                </div>


                                <span>
                                    {{oponente}}
                                </span>

                            </div>

                            <div>

                                {{resultado}}

                                {{#gano}}
                                    <i class="bi bi-trophy-fill icono-ranking"></i>
                                {{/gano}}

                                {{#perdio}}
                                    <span class="result-lose">✖</span>
                                {{/perdio}}

                            </div>

                        </div>

                        {{/historial}}

                        {{^historial}}

                        <p class="empty-text">
                            No hay partidas jugadas.
                        </p>

                        {{/historial}}

                    </div>

                </div>

            </div>

        </main>

    </div>

</div>
{{#compraExitosa}}
    <div class="modal fade" id="modalExitoCompra" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content text-center p-4">
                <div class="modal-body">
                    <div class="text-success mb-3" style="font-size: 3rem;">
                        ✓
                    </div>
                    <h3 class="modal-title font-weight-bold text-success mb-2">¡Compra Exitosa!</h3>
                    <p class="text-muted">
                        Tu pago se procesó correctamente. Se han acreditado <strong>{{cantidadTrampitas}}</strong> trampitas a tu cuenta. ¡Úsalas con sabiduría!
                    </p>
                    <button type="button" class="btn btn-success px-4 mt-3" data-bs-dismiss="modal">Buenísimo</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var myModal = new bootstrap.Modal(document.getElementById('modalExitoCompra'));
            myModal.show();
        });
    </script>
{{/compraExitosa}}

{{#compraFallida}}
    <div class="alert alert-danger alert-dismissible fade show text-center m-3" role="alert">
        <strong>Hubo un problema:</strong> El pago fue rechazado o cancelado. Inténtalo de nuevo.
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
{{/compraFallida}}
<script>
    document.addEventListener("DOMContentLoaded", function() {
        const inputCantidad = document.getElementById("cantidadTrampitas");
        const txtTotal = document.getElementById("totalPrecio");
        const PRECIO_UNITARIO = 1;

        inputCantidad.addEventListener("input", function() {
            let cantidad = parseInt(this.value) || 0;

            // Evitar que pongan números negativos manualmente
            if (cantidad < 1) {
                cantidad = 1;
                this.value = 1;
            }

            // Calcular y formatear el total
            const total = cantidad * PRECIO_UNITARIO;
            document.getElementById("inputTotal").value = total;
            txtTotal.textContent = `$${total.toLocaleString('es-AR')}`;
        });
    });
</script>

{{>footer}}