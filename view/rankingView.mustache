{{>header}}
<div class="container pt-5 d-flex justify-content-start">
    <div class="mb-3">
    <a href="/lobby/irAlLobby" class="btn btn-outline-secondary btn-sm boton-backto">&larr; Volver al Lobby</a>
</div>
</div>
<div class="container d-flex flex-column align-items-center">
    <h1 class="text-center mb-4">🏆 Ranking Global</h1>

    <div class="ranking-card">
        <div class="table-responsive">
            <table class="table table-ranking align-middle m-0">
                <thead>
                <tr>
                    <th scope="col" class="text-start px-4">Posición</th>
                    <th scope="col" class="text-start">Usuario</th>
                    <th scope="col" class="text-end px-4">Puntaje</th>
                </tr>
                </thead>
                <tbody>
              {{#usuarios}}
                    <tr>
                        <td class="pos text-start px-4">#{{posicion}}</td>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <img class="avatar rounded-circle"
                                 src="{{foto_perfil}}" 
                                 alt="Foto de {{nombre_usuario}}">

                                <a href="/usuario/verPerfil?id={{id}}">{{nombre_usuario}}</a>
                            </div>
                        </td>
                        <td class="score text-end px-4">{{puntaje}} pts</td>
                    </tr>
                {{/usuarios}}

                {{^usuarios}}
                    <tr>
                        <td colspan="3" class="text-center text-muted py-4">
                            No hay usuarios registrados en el ranking aún.
                        </td>
                    </tr>
                {{/usuarios}}
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>