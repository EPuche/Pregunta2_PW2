<!DOCTYPE html>
<html lang="es">
<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@100;300;400;500;700;900&display=swap" rel="stylesheet">

    <style>
        body{
            margin:0;
            min-height:100vh;
            background-image:url('assets/img/imagen-fondo.png');
            background-size:cover;
            background-position:center;
            background-repeat:no-repeat;
            font-family: 'Montserrat';
            font-weight:450;
        }

        .contenedor-principal{
            min-height:100vh;

            display:flex;
            justify-content:center;
            align-items:center;

            background:rgba(0,0,0,.45);
        }

        .contenedor-login{
            width:500px;
            max-width:90%;

            background:#add8e6;
            padding:40px;

            border-radius:15px;

            box-shadow:0 0 25px rgba(0,0,0,.5);
        }
        h2{
            text-align:center;
            font-weight:300;
            margin-bottom:30px;
        }

        .btn-login{
            width:100%;
            background:#ff9232;
            border:none;
            color:black;
            font-weight:bold;
            padding:12px;
        }
        .btn-login:hover{
            background:#ff9232;
            color:black;
            box-shadow:0 0 10px rgba(0,0,0,.4);
        }

        p{
            text-align:center;
            margin-top:20px;
        }

        a{
            color:#ff9232;
            text-decoration:none;
            font-weight:bold;
        }

    </style>
</head>

<body>

<div class="contenedor-principal">

    <div class="contenedor-login">
        <a href="/Pregunta2_PW2/index.php?controller=home&method=irAlHome" class="text-decoration-none text-secondary">HOME</a>
        {{#error}}
        <div class="alert alert-warning">
            {{error}}
        </div>
        {{/error}}
        <div class="contenedor-logo ms-4 mb-4">
            <img src="assets/logo.png" alt="Preguntados logo" class="img-fluid logo d-block mx-auto">
        </div>
        <form method="POST" action="/Pregunta2_PW2/index.php?controller=login&method=autenticar">
            <h2>Ingresa a tu cuenta</h2>

            <div class="mb-3">
                <label class="form-label">NOMBRE DE USUARIO</label>
                <input type="text" name="usuario" class="form-control">
            </div>

            <div class="mb-3">
                <label class="form-label">CONTRASEÑA</label>
                <input type="password" name="contrasenia" class="form-control">
            </div>

            <button type="submit" class="btn btn-login">INGRESAR</button>

            <hr>

            <p>¿NUEVO EN PREGUNTA2?<br>
                <a href="/Pregunta2_PW2/index.php?controller=registro&method=irAlRegistro">ABRIR CUENTA</a>
            </p>

        </form>

    </div>

</div>

</body>
</html>
