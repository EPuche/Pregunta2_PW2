<style>
    .btn-opcion {
        padding: 10px;
        margin: 5px 0;
        background-color: #f0f0f0;
        border: 2px solid #ccc;
        cursor: pointer;
        display: block;
        width: 200px;
    }
    .btn-correcta {
        border: 2px solid green !important;
        background-color: #e6ffe6;
    }
    .btn-incorrecta {
        border: 2px solid red !important;
        background-color: #ffe6e6;
    }
    .badge {
        font-weight: bold;
        margin-left: 10px;
    }
    .badge-correcta { color: green; }
    .badge-incorrecta { color: red; }
</style>

<h2>{{contenido}}</h2>
<h2>{{puntaje}}</h2>
<form action="/partida/verificarRespuesta" method="POST">
    <input type="hidden" name="id_pregunta" value="{{id}}">
    <ul>
        {{#opciones}}
            <li>
                <button type="submit"
                        name="opcion_elegida"
                        value="{{id}}"
                        class="btn-opcion
                               {{#ya_respondio}}
                            {{#opcion_correcta}}btn-correcta{{/opcion_correcta}}
                            {{#es_incorrecta}}btn-incorrecta{{/es_incorrecta}}
                        {{/ya_respondio}}"
                        {{#ya_respondio}}disabled{{/ya_respondio}}>
                    {{contenido}}
                </button>

                {{#ya_respondio}}
                    {{#opcion_correcta}}
                        <span class="badge badge-correcta">¡Correcta!</span>
                    {{/opcion_correcta}}
                    {{#es_incorrecta}}
                        <span class="badge badge-incorrecta">¡Incorrecta!</span>
                    {{/es_incorrecta}}
                {{/ya_respondio}}
            </li>
        {{/opciones}}
    </ul>
</form>

{{#ya_respondio}}
    {{#opciones}}
        {{#es_elegida}}
            {{#opcion_correcta}}
                <a href="/partida/jugar" class="btn btn-success">Continuar</a>
            {{/opcion_correcta}}
        {{/es_elegida}}
    {{/opciones}}

    {{#opciones}}
        {{#es_incorrecta}}
            <div class="alert alert-danger" style="margin-top: 15px;">¡Respuesta Incorrecta! Juego Terminado.</div>
            <p>Tu puntaje final fue: <strong>{{puntaje}}</strong></p>
            <a href="/lobby/irAlLobby" class="btn btn-primary">Volver al Lobby</a>
        {{/es_incorrecta}}
    {{/opciones}}

{{/ya_respondio}}