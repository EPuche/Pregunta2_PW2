{{>header}}
<div class="quiz-container">

<form action="/partida/verificarRespuesta" method="POST" style="background-color:{{color}};">

    <button type="button" class="btn btn-reportar" data-bs-toggle="modal" data-bs-target="#modalReporte">
        <i class="bi-exclamation-triangle"></i>
    </button>
    <h2 class="pregunta">{{contenido}}</h2>

<h2>{{contenido}}</h2>
<h2>{{puntaje}}</h2>
<form action="/partida/verificarRespuesta" method="POST">
    <input type="hidden" name="id_pregunta" value="{{id}}">

    <div class="d-grid gap-3 opciones">
        {{#opciones}}
            <button type="submit"
                    name="opcion_elegida"
                    value="{{id}}"
                    class="btn btn-lg opcion-btn
                   {{#ya_respondio}}
                        {{#mostrar_correcta}}btn-correcta{{/mostrar_correcta}}
                        {{#mostrar_incorrecta}}btn-incorrecta{{/mostrar_incorrecta}}
                    {{/ya_respondio}}"
                    {{#ya_respondio}}disabled{{/ya_respondio}}>

                {{contenido}}
            </button>
            <li>
                <button type="submit"
                        name="opcion_elegida"
                        value="{{id}}"
                        class="btn-opcion
                               {{#ya_respondio}}
                            {{#opcion_correcta}}btn-correcta{{/opcion_correcta}}
                            {{#es_incorrecta}}btn-incorrecta{{/es_incorrecta}}
                        {{/ya_respondio}}"
                        {{#ya_respondio}}disabled{{/ya_respondio}}>
                    {{contenido}}
                </button>


                {{#ya_respondio}}
                    {{#opcion_correcta}}
                        <span class="badge badge-correcta">¡Correcta!</span>
                    {{/opcion_correcta}}
                    {{#es_incorrecta}}
                        <span class="badge badge-incorrecta">¡Incorrecta!</span>
                    {{/es_incorrecta}}
                {{/ya_respondio}}

        {{/opciones}}
        </div>
    {{#ya_respondio}}
        <div style="margin-top: 20px;">
            <a href="/partida/crearPartida">
                <button type="button" class="btn-continuarPartida" style="padding: 10px 20px; font-weight: bold;">Siguiente pregunta</button>
            </a>
        </div>
    {{/ya_respondio}}

</form>

</div>
<!--modal-->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
    </ul>
</form>

{{#ya_respondio}}
    {{#opciones}}
        {{#es_elegida}}
            {{#opcion_correcta}}
                <a href="/partida/jugar" class="btn btn-success">Continuar</a>
            {{/opcion_correcta}}
        {{/es_elegida}}
    {{/opciones}}

    {{#opciones}}
        {{#es_incorrecta}}
            <div class="alert alert-danger" style="margin-top: 15px;">¡Respuesta Incorrecta! Juego Terminado.</div>
            <p>Tu puntaje final fue: <strong>{{puntaje}}</strong></p>
            <a href="/lobby/irAlLobby" class="btn btn-primary">Volver al Lobby</a>
        {{/es_incorrecta}}
    {{/opciones}}

{{/ya_respondio}}