<style>
    .btn-opcion {
        padding: 10px;
        margin: 5px 0;
        background-color: #f0f0f0;
        border: 2px solid #ccc;
        cursor: pointer;
        display: block;
        width: 200px;
    }
    .btn-correcta {
        border: 2px solid green !important;
        background-color: #e6ffe6;
    }
    .btn-incorrecta {
        border: 2px solid red !important;
        background-color: #ffe6e6;
    }
    .badge {
        font-weight: bold;
        margin-left: 10px;
    }
    .badge-correcta { color: green; }
    .badge-incorrecta { color: red; }
</style>

<h2>{{contenido}}</h2>

<form action="/partida/verificarRespuesta" method="POST">
    <input type="hidden" name="id_pregunta" value="{{id}}">
    <ul>
        {{#opciones}}
            <li>
                <button type="submit"
                        name="opcion_elegida"
                        value="{{id}}"
                        class="btn-opcion {{#ya_respondio}}{{#mostrar_correcta}}btn-correcta{{/mostrar_correcta}} {{#mostrar_incorrecta}}btn-incorrecta{{/mostrar_incorrecta}}{{/ya_respondio}}"
                        {{#ya_respondio}}disabled{{/ya_respondio}}>
                    {{contenido}}
                </button>

                {{#ya_respondio}}
                    {{#mostrar_correcta}}
                        <span class="badge badge-correcta">¡Correcta!</span>
                    {{/mostrar_correcta}}
                    {{#mostrar_incorrecta}}
                        <span class="badge badge-incorrecta">¡Incorrecta!</span>
                    {{/mostrar_incorrecta}}
                {{/ya_respondio}}
            </li>
        {{/opciones}}
    </ul>
</form>

{{#ya_respondio}}
    <div style="margin-top: 20px;">
        <a href="/partida/crearPartida">
            <button type="button" style="padding: 10px 20px; font-weight: bold;">Siguiente pregunta</button>
        </a>
    </div>
{{/ya_respondio}}