{{>header}}

<div class="container-fluid lobby-container">
  <div class="row">

    <aside class="col-lg-2 sidebar">
      <div class="d-flex flex-column gap-3 px-3">
        <a href="/admin/verEstadisticas" class="btn lobby-btn">Dashboard</a>
        <a href="/admin/usuarios" class="btn lobby-btn active">Usuarios</a>
        <a href="/admin/partidas" class="btn lobby-btn">Partidas</a>
        <a href="/admin/preguntas" class="btn lobby-btn">Preguntas</a>
        <a href="/admin/trampitas" class="btn lobby-btn">Trampitas / Ventas</a>
        <a href="/logout" class="btn lobby-btn">Salir</a>
      </div>
    </aside>

    <main class="col-lg-10 p-4">
      <h2 class="panel-title mb-4">Usuarios</h2>

      <!-- Buscador -->
      <form method="GET" class="mb-3 d-flex gap-2">
        <input type="text" name="q" class="form-control" placeholder="Buscar usuario...">
        <button type="submit" class="btn lobby-btn">Buscar</button>
      </form>

      <!-- Tabla de usuarios -->
      <div class="panel profile-panel">
        <table class="table table-striped">
          <thead>
            <tr>
              <th>ID</th>
              <th>Nombre</th>
              <th>Email</th>
              <th>Puntaje</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            {{#usuarios}}
              <tr>
                <td>{{id}}</td>
                <td>{{nombre_usuario}}</td>
                <td>{{email}}</td>
                <td>{{puntaje}}</td>
                <td>
                  <a href="/usuario/verPerfil?id={{id}}" class="btn btn-principal">Ver perfil</a>
                </td>
              </tr>
            {{/usuarios}}
          </tbody>
        </table>
      </div>
    </main>
  </div>
</div>

{{>footer}}
