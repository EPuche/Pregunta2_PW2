<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{titulo}}</title>

    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap"
          rel="stylesheet">

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        :root{
            --dark:#222323;
            --orange:#FF9232;
            --pink:#FFB6B2;
            --green:#C1E1C1;
            --yellow:#FFFACD;
            --blue:#ADD8E6;
            --white:#FFFFFF;
        }

        body{
            font-family:'Montserrat',sans-serif;
            background:var(--dark);
            min-height:100vh;
            color:var(--dark);
            padding:30px;

            /* estilos loginView */
            background-image:url('assets/img/imagen-fondo.png');
            background-size:cover;
            background-position:center;
            background-repeat:no-repeat;
        }

        header{
            display:flex;
            justify-content:space-between;
            align-items:center;

            background:var(--blue);

            padding:20px 40px;

            border-radius:10px 10px 0 0;

            box-shadow:
                    0 0 25px rgba(255,255,255,.08),
                    0 10px 40px rgba(0,0,0,.45);
        }

        .logo{
            height:80px;
            width:auto;
        }

        .user-menu{
            position:relative;
        }

        .user-button{
            background:var(--orange);
            color:white;
            padding:12px 18px;
            border-radius:6px;
            font-family:'Montserrat',sans-serif;
            font-weight:600;
            cursor:pointer;
        }

        /* menú desplegable solo con hover */
        .user-menu:hover .dropdown-menu{
            display:block;
        }

        .dropdown-menu{
            display:none;
            position:absolute;
            top:100%;
            right:0;
            background:white;
            border-radius:6px;
            overflow:hidden;
            margin-top:5px;
            box-shadow:0 2px 8px rgba(0,0,0,.2);
            min-width:150px;
        }

        .dropdown-menu a{
            display:block;
            padding:10px 15px;
            color:#222;
            text-decoration:none;
            font-weight:500;
        }

        .dropdown-menu a:hover{
            background:#f0f0f0;
        }

        .container{
            max-width:1000px;
            margin:0 auto 50px auto;

            background:var(--blue);

            padding:40px;

            border-radius:10px 10px 10px 10px;

            box-shadow:
                    0 0 25px rgba(255,255,255,.08),
                    0 10px 40px rgba(0,0,0,.45);

            /* estilos loginView */
            display:flex;
            justify-content:center;
            align-items:center;
            flex-direction:column;
            min-height:600px;
            background: rgba(173,216,230,0.95); /* fondo azul con opacidad */
        }

        h2{
            font-size:28px;
            font-weight:600;
            text-align:center;
            margin-bottom:30px;
            color:var(--dark);
        }

        /* botones combinados loginView + header */
        .btn-add,
        .btn-submit,
        .btn-login,
        .btn-registro{
            display:inline-block;

            background:var(--orange);
            color:white;

            border:none;

            border-radius:4px;

            padding:14px 24px;

            font-family:'Montserrat',sans-serif;
            font-size:14px;
            font-weight:700;

            text-transform:uppercase;
            text-decoration:none;

            cursor:pointer;

            transition:.25s;
        }

        .btn-submit,
        .btn-login,
        .btn-registro{
            width:100%;
        }

        .btn-add:hover,
        .btn-submit:hover,
        .btn-login:hover,
        .btn-registro:hover{
            transform:translateY(-2px);
            filter:brightness(.95);
            box-shadow:0 0 10px rgba(0,0,0,.4);
        }

        .form-group{
            margin-bottom:18px;
        }

        .form-group label{
            display:block;

            font-size:11px;
            font-weight:600;

            text-transform:uppercase;

            margin-bottom:6px;

            color:var(--dark);
        }

        .form-group input,
        .form-group select,
        .form-group textarea{
            width:100%;

            height:42px;

            border:none;

            border-radius:4px;

            background:var(--white);

            padding:0 12px;

            font-family:'Montserrat',sans-serif;
            font-size:14px;

            color:var(--dark);
        }

        .form-group textarea{
            height:120px;
            padding:12px;
            resize:vertical;
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus{
            outline:2px solid var(--orange);
        }

        /* resto de estilos del header original se mantiene */
        table{
            width:100%;
            border-collapse:collapse;

            background:var(--white);

            border-radius:8px;

            overflow:hidden;

            box-shadow:0 2px 10px rgba(0,0,0,.1);
        }

        th{
            background:var(--orange);
            color:white;

            padding:15px;

            text-align:left;

            font-size:13px;
            font-weight:700;
            text-transform:uppercase;
        }

        td{
            padding:15px;
            border-bottom:1px solid #ececec;
            font-size:14px;
        }

        tr:last-child td{
            border-bottom:none;
        }

        tr:hover{
            background:#f7f7f7;
        }

        .actions a{
            text-decoration:none;
            padding:8px 12px;
            border-radius:4px;
            font-size:13px;
            font-weight:600;
            margin-right:5px;
            transition:.2s;
        }

        .edit{
            background:var(--blue);
            color:var(--dark);
        }

        .edit:hover{
            opacity:.8;
        }

        .delete{
            background:var(--pink);
            color:var(--dark);
        }

        .delete:hover{
            opacity:.8;
        }

        .success{
            background:var(--green);
            color:var(--dark);

            padding:15px;
            border-radius:6px;

            margin-bottom:20px;
        }

        .warning{
            background:var(--yellow);
            color:var(--dark);

            padding:15px;
            border-radius:6px;

            margin-bottom:20px;
        }

        .error{
            background:var(--pink);
            color:var(--dark);

            padding:15px;
            border-radius:6px;

            margin-bottom:20px;
        }

        .back-link{
            display:block;
            text-align:center;
            margin-top:20px;

            color:var(--dark);
            text-decoration:none;
            font-weight:500;
        }

        .back-link:hover{
            color:var(--orange);
        }

        @media (max-width:768px){

            body{
                padding:15px;
            }

            header h1{
                font-size:32px;
            }

            .container{
                padding:25px;
            }

            table{
                display:block;
                overflow-x:auto;
            }
        }

        .dashboard{
            display:flex;
            min-height:600px;
        }

        .sidebar{
            width:220px;

            background:#111;

            padding:25px;

            display:flex;
            flex-direction:column;
            gap:15px;
        }

        .menu-btn{
            background:#FF9232;
            color:white;

            text-decoration:none;

            padding:14px;

            border-radius:5px;

            text-align:center;

            font-weight:700;

            transition:.2s;
        }

        .menu-btn:hover{
            transform:translateY(-2px);
        }

        .main-content{
            flex:1;

            padding:30px;
        }

        .user-panel{
            display:flex;
            align-items:center;
            gap:20px;
            margin-bottom:40px;
            color: #DDDDDD;
        }

        .user-avatar{
            width:90px;
            height:90px;

            border-radius:50%;

            background:#444;

            color:white;

            display:flex;
            justify-content:center;
            align-items:center;

            font-weight:700;
        }

        .user-info h3{
            margin:0;
            font-size:22px;
            color:#222323;
        }

        .user-info p{
            margin-top:5px;
            font-size:16px;
        }



        .matches-section h2{
            text-align:left;
            margin-bottom:20px;
            color: #DDDDDD;
        }

        .game-panels{
            display:flex;
            gap:30px;
            align-items:flex-start;
        }

        .panel-box{
            flex:1;
        }

        .panel-box h2{
            text-align:left;
            margin-bottom:20px;

            color:#FFFFFF;

            text-transform:uppercase;

            font-size:28px;
            font-weight:800;
        }

        .active-panel .matches-list{
            min-height:380px;

            border:1px solid var(--green);
            border-radius:8px;

            padding:15px;

            box-shadow:
                    0 0 5px rgba(193,225,193,.5),
                    0 0 15px rgba(193,225,193,.25);
        }

        .history-panel .matches-list{
            min-height:380px;

            border:1px solid var(--pink);
            border-radius:8px;

            padding:15px;

            box-shadow:
                    0 0 5px rgba(255,182,178,.5),
                    0 0 15px rgba(255,182,178,.25);
        }

        .matches-list{
            display:flex;
            flex-direction:column;
            gap:12px;
        }

        .match-card{
            background:#4A4A4A;

            color:white;

            border-radius:5px;

            padding:10px 15px;

            display:flex;
            align-items:center;

            gap:12px;
        }

        .opponent-avatar{
            width:35px;
            height:35px;

            border-radius:50%;

            background:#D9D9D9;
            color:#222323;

            display:flex;
            align-items:center;
            justify-content:center;

            font-size:10px;
            font-weight:700;
        }

        .opponent-name{
            flex:1;

            color:white;

            font-size:12px;
            font-weight:700;

            text-transform:uppercase;
        }

        .match-result{
            color:white;

            font-size:22px;
            font-weight:800;
        }

        .empty-state{
            border-radius:6px;

            border-color: #C1E1C1;

            color: #DDDDDD;

            padding:15px;

            display:flex;
            align-items:center;

            gap:15px;

            box-shadow:0 0 5px #ADD8E6, 0 0 15px rgba(173,216,230,.5),0 0 25px rgba(173,216,230,.25);

            text-align:center;
        }

    </style>
</head>
