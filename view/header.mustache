<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{titulo}}</title>

    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap"
          rel="stylesheet">

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        :root{
            --dark:#222323;
            --orange:#FF9232;
            --pink:#FFB6B2;
            --green:#C1E1C1;
            --yellow:#FFFACD;
            --blue:#ADD8E6;
            --white:#FFFFFF;
        }

        body{
            font-family:'Montserrat',sans-serif;
            background:var(--dark);
            min-height:100vh;
            color:var(--dark);
            padding:30px;
        }

        header{
            display:flex;
            flex-direction:column;
            align-items:center;
            justify-content:center;
            text-align:center;

            background:var(--blue);

            max-width:1000px;
            margin:0 auto;

            padding:40px 40px 25px;

            border-radius:10px 10px 0 0;

            box-shadow:
                    0 0 25px rgba(255,255,255,.08),
                    0 10px 40px rgba(0,0,0,.45);
        }

        header h1{
            font-size:42px;
            font-weight:800;
            color:var(--dark);
            text-transform:uppercase;
            margin-bottom:10px;
        }

        header h1 span{
            color:var(--orange);
        }

        header p{
            font-size:18px;
            font-weight:400;
            color:var(--dark);
        }

        .container{
            max-width:1000px;
            margin:0 auto 50px auto;

            background:var(--blue);

            padding:40px;

            border-radius:0 0 10px 10px;

            box-shadow:
                    0 0 25px rgba(255,255,255,.08),
                    0 10px 40px rgba(0,0,0,.45);
        }

        h2{
            font-size:28px;
            font-weight:600;
            text-align:center;
            margin-bottom:30px;
            color:var(--dark);
        }

        /* BOTONES */

        .btn-add,
        .btn-submit{
            display:inline-block;

            background:var(--orange);
            color:white;

            border:none;

            border-radius:4px;

            padding:14px 24px;

            font-family:'Montserrat',sans-serif;
            font-size:14px;
            font-weight:700;

            text-transform:uppercase;
            text-decoration:none;

            cursor:pointer;

            transition:.25s;
        }

        .btn-submit{
            width:100%;
        }

        .btn-add:hover,
        .btn-submit:hover{
            transform:translateY(-2px);
            filter:brightness(.95);
        }

        /* FORMULARIOS */

        .form-group{
            margin-bottom:18px;
        }

        .form-group label{
            display:block;

            font-size:11px;
            font-weight:600;

            text-transform:uppercase;

            margin-bottom:6px;

            color:var(--dark);
        }

        .form-group input,
        .form-group select,
        .form-group textarea{
            width:100%;

            height:42px;

            border:none;

            border-radius:4px;

            background:var(--white);

            padding:0 12px;

            font-family:'Montserrat',sans-serif;
            font-size:14px;

            color:var(--dark);
        }

        .form-group textarea{
            height:120px;
            padding:12px;
            resize:vertical;
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus{
            outline:2px solid var(--orange);
        }

        /* TABLAS */

        table{
            width:100%;
            border-collapse:collapse;

            background:var(--white);

            border-radius:8px;

            overflow:hidden;

            box-shadow:0 2px 10px rgba(0,0,0,.1);
        }

        th{
            background:var(--orange);
            color:white;

            padding:15px;

            text-align:left;

            font-size:13px;
            font-weight:700;
            text-transform:uppercase;
        }

        td{
            padding:15px;
            border-bottom:1px solid #ececec;
            font-size:14px;
        }

        tr:last-child td{
            border-bottom:none;
        }

        tr:hover{
            background:#f7f7f7;
        }

        /* ACCIONES */

        .actions a{
            text-decoration:none;
            padding:8px 12px;
            border-radius:4px;
            font-size:13px;
            font-weight:600;
            margin-right:5px;
            transition:.2s;
        }

        .edit{
            background:var(--blue);
            color:var(--dark);
        }

        .edit:hover{
            opacity:.8;
        }

        .delete{
            background:var(--pink);
            color:var(--dark);
        }

        .delete:hover{
            opacity:.8;
        }

        /* MENSAJES */

        .success{
            background:var(--green);
            color:var(--dark);

            padding:15px;
            border-radius:6px;

            margin-bottom:20px;
        }

        .warning{
            background:var(--yellow);
            color:var(--dark);

            padding:15px;
            border-radius:6px;

            margin-bottom:20px;
        }

        .error{
            background:var(--pink);
            color:var(--dark);

            padding:15px;
            border-radius:6px;

            margin-bottom:20px;
        }

        .back-link{
            display:block;
            text-align:center;
            margin-top:20px;

            color:var(--dark);
            text-decoration:none;
            font-weight:500;
        }

        .back-link:hover{
            color:var(--orange);
        }

        @media (max-width:768px){

            body{
                padding:15px;
            }

            header h1{
                font-size:32px;
            }

            .container{
                padding:25px;
            }

            table{
                display:block;
                overflow-x:auto;
            }
        }

    </style>
</head>
<body>

<header>
    <h1>Salón del Trono</h1>
    <p>"AQUÍ SE FORJAN LAS LEYENDAS QUE CANTARÁN LOS SKALDOS"</p>
</header>