{{>header}}
<div class="container">
    <form action="/vikingo/procesarAlta" method="POST" style="display:flex; flex-wrap:wrap; gap:20px;">

        <!-- COLUMNA FOTO -->
        <div style="flex:1 1 200px; display:flex; flex-direction:column; align-items:center; text-align:center;">
            <div style="width:120px; height:120px; border-radius:50%; background:#fff; display:flex; align-items:center; justify-content:center; font-size:16px; color:#222323; margin-bottom:8px;">
                Foto
            </div>
            <small style="color:#555;">Seleccionar imagen</small>
        </div>

        <!-- COLUMNA IZQUIERDA DATOS -->
        <div style="flex:1 1 250px; display:flex; flex-direction:column; gap:15px;">
            <div class="form-group">
                <label for="nombre">Nombre del Guerrero</label>
                <input type="text" id="nombre" name="nombre" placeholder="Ej: Ragnar" required>
            </div>

            <div class="form-group">
                <label for="apodo">Apodo (Si lo tiene)</label>
                <input type="text" id="apodo" name="apodo" placeholder="Ej: Lothbrok">
            </div>

            <div class="form-group">
                <label for="clan">Clan / Asentamiento</label>
                <input type="text" id="clan" name="clan" placeholder="Ej: Kattegat">
            </div>
        </div>

        <!-- COLUMNA DERECHA DATOS -->
        <div style="flex:1 1 250px; display:flex; flex-direction:column; gap:15px;">
            <div class="form-group">
                <label for="fuerza">Nivel de Fuerza (0 - 100)</label>
                <input type="number" id="fuerza" name="fuerza" min="0" max="100" value="50">
            </div>

            <div class="form-group">
                <label for="edad">Año de Nacimiento</label>
                <input type="date" id="edad" name="edad">
            </div>

            <div class="form-group">
                <label for="sexo">Sexo</label>
                <select id="sexo" name="sexo">
                    <option value="">Seleccione...</option>
                    <option value="M">Masculino</option>
                    <option value="F">Femenino</option>
                </select>
            </div>
        </div>

        <!-- BOTÓN Y LINK -->
        <div style="flex-basis:100%; margin-top:20px;">
            <button type="submit" class="btn-submit">Registrarme</button>
            <a href="/vikingo" class="back-link">← Volver al Salón del Trono</a>
        </div>

    </form>
</div>
{{>footer}}